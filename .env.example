STAC_HOST=0.0.0.0
STAC_PORT=7822
CATALOG_TITLE=LAPIG Data Catalog
CATALOG_DESCRIPTION=Catálogo de dados geoespaciais do LAPIG/UFG
# Desenvolvimento: http://localhost:7822
# Produção: https://stac.lapig.iesa.ufg.br
PUBLIC_URL=http://localhost:7822

# === Banco de dados (stac-fastapi-pgstac) ================================
# Em dev, o docker-compose sobe um serviço `db` (PostGIS 17 + pgstac).
# Em prod, DATABASE_URL é injetada pelo orquestrador apontando para o
# Postgres institucional, em um database dedicado (ex.: stac_lapig).
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=stac_lapig
POSTGRES_HOST_PORT=5433
DATABASE_URL=postgresql://postgres:postgres@db:5432/stac_lapig

# === Mapbox (basemap do browser) =========================================
MAPBOX_TOKEN=pk.xxxxxx
